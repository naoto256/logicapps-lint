{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workflowNames": {
      "type": "array",
      "defaultValue": []
    }
  },
  "resources": [
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('workflowNames')[copyIndex()]]",
      "location": "westus",
      "copy": {
        "name": "workflowcopy",
        "count": "[length(parameters('workflowNames'))]"
      },
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
          "triggers": {
            "manual": {
              "type": "Request",
              "kind": "Http",
              "inputs": {
                "schema": {}
              }
            }
          },
          "actions": {
            "Bad": {
              "type": "NotARealAction",
              "inputs": {},
              "runAfter": {}
            }
          },
          "outputs": {}
        },
        "parameters": {}
      }
    }
  ]
}

{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "path": { "type": "String", "defaultValue": "" },
    "tail": { "type": "String", "defaultValue": "" }
  },
  "triggers": {
    "manual": {
      "type": "Request",
      "kind": "Http",
      "inputs": { "schema": {} }
    }
  },
  "actions": {
    "NoScheme": {
      "type": "Http",
      "inputs": {
        "method": "GET",
        "uri": "example.com/@{parameters('path')}"
      },
      "runAfter": {}
    },
    "EmptyHost": {
      "type": "Http",
      "inputs": {
        "method": "GET",
        "uri": "https:///api/@{parameters('tail')}"
      },
      "runAfter": {}
    }
  },
  "outputs": {}
}

{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "triggers": {
    "manual": {
      "type": "Request",
      "kind": "Http",
      "inputs": {
        "schema": {}
      }
    }
  },
  "actions": {
    "Producer": {
      "type": "Compose",
      "inputs": "ok",
      "runAfter": {}
    },
    "Consumer": {
      "type": "Compose",
      "inputs": "@outputs('Producer' 'extra')",
      "runAfter": {
        "Producer": [
          "Succeeded"
        ]
      }
    }
  },
  "outputs": {}
}

{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "triggers": {
    "Poll": {
      "type": "Http",
      "inputs": {
        "method": "GET",
        "uri": "https://example.com",
        "cookie": 42
      },
      "recurrence": {
        "frequency": "Minute",
        "interval": 1
      }
    }
  },
  "actions": {
    "Call": {
      "type": "Http",
      "inputs": {
        "method": "GET",
        "uri": "https://example.com",
        "cookie": 42
      },
      "runAfter": {}
    }
  }
}

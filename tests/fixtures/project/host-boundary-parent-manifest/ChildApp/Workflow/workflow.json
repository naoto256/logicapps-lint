{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "NeedsChildValue": {
        "type": "String"
      }
    },
    "triggers": {"manual":{"type":"Request","kind":"Http","inputs":{"schema":{}}}},
    "actions": {
      "Use_Parameter": {
        "type": "Compose",
        "inputs": "@parameters('NeedsChildValue')",
        "runAfter": {}
      },
      "Use_Connection": {
        "type": "ApiConnection",
        "inputs": {
          "host": {
            "connection": {
              "referenceName": "office365"
            }
          },
          "method": "GET",
          "path": "/send"
        },
        "runAfter": {
          "Use_Parameter": [
            "Succeeded"
          ]
        }
      }
    }
  },
  "kind": "Stateful"
}

{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "parameters": {
    "tenantName": {
      "type": "string"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "sample",
      "properties": {
        "definition": {
          "actions": {
            "Use_Template_Parameter": {
              "type": "Compose",
              "inputs": "@parameters('tenantName')",
              "runAfter": {}
            }
          },
          "triggers": {
            "When_event_arrives": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "path": "[concat('/subscriptions/@{encodeURIComponent(', variables('singlequote'), subscription().subscriptionId, variables('singlequote'), ')}/resource/eventSubscriptions')]"
              }
            }
          }
        }
      }
    }
  ]
}
